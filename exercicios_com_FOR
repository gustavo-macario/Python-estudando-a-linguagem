# DESAFIO 2: Números pares de 1 a 50
print("\nDesafio 2:")
for i in range(1, 51):
    if i % 2 == 0:
        print(i, end=' ')
print("\nFIM")

# DESAFIO 3: Soma de ímpares múltiplos de 3 (1 até 500)
print("\nDesafio 3:")
soma = 0
for i in range(1, 501):
    if i % 3 == 0 and i % 2 == 1:
        soma += i
print(f"A soma de todos os valores solicitados é {soma}")

# DESAFIO 4: Tabuada v2.0
print("\nDesafio 4:")
num = int(input('Informe um numero para ver sua tabuada: '))
for i in range(1, 11):
    print(f'{num} x {i} = {num * i}')

# DESAFIO 5: Soma dos pares (leitura de 6 números)
print("\nDesafio 5:")
soma_pares = 0
for i in range(0, 6):
    num = int(input(f'Digite o {i+1}º valor: '))
    if num % 2 == 0:
        soma_pares += num
print(f'A soma dos números pares digitados é: {soma_pares}')

# DESAFIO 6: Progressão Aritmética (10 primeiros termos)
