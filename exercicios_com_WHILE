# =========================
# DESAFIO 15: Maior idade
# =========================
print("\nDesafio 15:")
idade = 0
maior = 0
qtde = 0

while idade >= 0:
    idade = int(input('Informe a sua idade: [< 0 PARA SAIR] '))

    if idade < 0:
        break

    qtde += 1

    if qtde == 1:
        maior = idade
    elif idade > maior:
        maior = idade

if qtde > 0:
    print('A maior idade foi:', maior)
else:
    print('Nenhuma idade válida foi digitada.')
