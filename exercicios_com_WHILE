# =========================
# DESAFIO 4: Menu de operações
# =========================
print("\nDesafio 4:")
num1 = int(input('Digite o primeiro valor: '))
num2 = int(input('Digite o segundo valor: '))
opcao = 0

while opcao != 5:
    print('\nESCOLHA UMA OPÇÃO')
    opcao = int(input('[1] SOMAR / [2] MULTIPLICAR / [3] MAIOR / [4] NOVOS NÚMEROS / [5] SAIR: '))

    if opcao == 1:
        print('Resultado:', num1 + num2)

    elif opcao == 2:
        print('Resultado:', num1 * num2)

    elif opcao == 3:
        print('Maior número:', max(num1, num2))

    elif opcao == 4:
        num1 = int(input('Digite o primeiro valor: '))
        num2 = int(input('Digite o segundo valor: '))

    elif opcao == 5:
        print('PROGRAMA ENCERRADO!')

    else:
        print('OPÇÃO INVÁLIDA!')


# =========================
# DESAFIO 5: Fatorial
# =========================
print("\nDesafio 5:")
num = int(input('Digite um número: '))
i = num
fatorial = 1

while i > 0:
    fatorial *= i
    i -= 1

print(f'Fatorial de {num} = {fatorial}')


# =========================
# DESAFIO 6: Progressão Aritmética (10 termos)
# =========================
print("\nDesafio 6:")
num = int(input('Termo: '))
razao = int(input('Razão: '))
contador = 0

while contador < 10:
    print(num, end=' > ')
    num += razao
    contador += 1

print('FIM')


# =========================
# DESAFIO 7: PA com mais termos
# =========================
print("\nDesafio 7:")
num = int(input('Termo: '))
razao = int(input('Razão: '))
total = 0
mais = 10
cont = 1

while mais != 0:
    total += mais
    while cont <= total:
        print(num, end=' > ')
        num += razao
        cont += 1

    print('PAUSA')
    mais = int(input('Quantos termos a mais quer mostrar? [0 para sair] '))

print('FIM')


# =========================
# DESAFIO 8: Sequência de Fibonacci
# =========================
print("\nDesafio 8:")
num = int(input('Digite o tamanho da sequência: '))
t1 = 0
t2 = 1

print(f'{t1} -> {t2}', end='')

contador = 2

while contador < num:
    t3 = t1 + t2
    print(f' -> {t3}', end='')

    t1 = t2
    t2 = t3
    contador += 1

print(' -> FIM')


