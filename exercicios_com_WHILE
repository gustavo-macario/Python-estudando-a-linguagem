# =========================
# DESAFIO 10: Média, maior e menor
# =========================
print("\nDesafio 10:")
num = soma = qtde = 0
maior = menor = 0
opcao = 1

while opcao == 1:
    num = int(input('Digite um número: '))
    soma += num
    qtde += 1

    if qtde == 1:
        maior = menor = num
    else:
        if num > maior:
            maior = num
        if num < menor:
            menor = num

    opcao = int(input('[1] INSERIR MAIS / [2] ENCERRAR: '))

media = soma / qtde if qtde > 0 else 0

print(f'Média: {media:.2f}')
print(f'Maior número: {maior}')
print(f'Menor número: {menor}')


