# =========================
# DESAFIO 13: Contador de pares e ímpares
# =========================
print("\nDesafio 13:")
qtde_pares = 0
qtde_impares = 0
num = 1

while num != 0:
    num = int(input('Digite um número (0 para parar): '))

    if num == 0:
        print('ENCERRADO!')
    elif num % 2 == 0:
        qtde_pares += 1
    else:
        qtde_impares += 1

print(f'Pares: {qtde_pares} | Ímpares: {qtde_impares}')


