    print(f'  {txt}')
    print('-' * tam)

escreva('Aprendendo Funções em Python')


# --- DESAFIO 3: Função de Contador ---
# Objetivo: Uma função que realiza contagens progressivas, regressivas e personalizadas.
print(f'\n{" DESAFIO 3 ":=^30}')
def contador():
    print('--- Contagem de 1 a 10 ---')
    for i in range(1, 11):
        print(f'{i} ', end='', flush=True)
        sleep(0.1)
    print('FIM!')

    print('--- Contagem de 10 a 0 (de 2 em 2) ---')
    for i in range(10, -1, -2):
        print(f'{i} ', end='', flush=True)
        sleep(0.1)
    print('FIM!')

    print('--- Agora é sua vez! ---')
    inicio = int(input('Início: '))
    fim = int(input('Fim:    '))
    passo = int(input('Passo:  '))

    if passo == 0:
        passo = 1
    passo = abs(passo)

    print(f'Contando de {inicio} até {fim} de {passo} em {passo}:')
    if inicio < fim:
        for i in range(inicio, fim + 1, passo):
            print(f'{i} ', end='', flush=True)
            sleep(0.1)
    elif inicio > fim:
        for i in range(inicio, fim - 1, -passo):
            print(f'{i} ', end='', flush=True)
            sleep(0.1)
    print('FIM!')

contador()


# --- DESAFIO 4: Função que descobre o Maior ---
# Objetivo: Utilizar empacotamento (*num) para receber vários valores e definir o maior.
print(f'\n{" DESAFIO 4 ":=^30}')
def maior(* num):
    print('-' * 30)
    if len(num) == 0:
        print('Nenhum valor informado!')
    else:
        m = max(num)
        print(f'Valores informados: ', end='')
        for v in num:
            print(f'{v} ', end='')
        print(f'\nForam informados {len(num)} valores ao todo.')
        print(f'O maior valor informado foi {m}.')

maior(1, 2, 3, 4, 5, 8)
maior(10, 53, 5, 3)
maior()


# --- DESAFIO 5: Funções para Sortear e Somar ---
# Objetivo: Uma função sorteia números para uma lista e outra soma apenas os pares sorteados.
print(f'\n{" DESAFIO 5 ":=^30}')
numeros = []

def sorteia():
    print('Sorteando 5 valores da lista: ', end='')
    for i in range(0, 5):
        n = random.randint(1, 100)
        numeros.append(n)
        print(f'{n} ', end='', flush=True)
        sleep(0.3)
    print('PRONTO!')

def somaPar():
    soma = 0
    for n in numeros:
        if n % 2 == 0:
            soma += n
    print(f'Somando os valores pares de {numeros}, temos: {soma}')

sorteia()
somaPar()

