# --- DESAFIO 7 ---
def fatorial(num, show=False):
    n = 1
    for v in range(num,0, -1):
        if show:
            print(v, end='')
            if(v > 1):
                print(' x ', end='')
            else:
                print(' = ', end='')
        n *= v
    return n

print(fatorial(5, show=True))


